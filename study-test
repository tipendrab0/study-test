// ── MCQ ──
function selectOpt(chosen){
  if(currentAnswered)return;
  const q=questions[currentIdx];
  currentAnswered=true;answered++;
  const isCorrect=chosen===q.ans;
  const pts=q.points||1;
  const earned=isCorrect?pts:0;
 
  if(isCorrect){score+=pts;streak++;if(streak>bestStreak)bestStreak=streak;}
  else streak=0;
  currentResult=isCorrect?'correct':'wrong';
  questionLog.push({text:q.text,result:currentResult,points:pts,earned});
 
  for(let i=0;i<(q.opts||[]).length;i++){
    const el=document.getElementById('opt'+i);if(!el)continue;
    el.onclick=null;
    if(i===q.ans) el.classList.add(isCorrect?'correct':'reveal-correct');
    if(i===chosen&&chosen!==q.ans) el.classList.add('wrong');
  }
 
  const fb=document.getElementById('feedbackBox');
  fb.className=`feedback-box ${isCorrect?'correct-fb':'wrong-fb'} show`;
  fb.innerHTML=`<div class="fb-headline">${isCorrect?'🎉 Correct!':'😅 Not quite!'}</div><div class="fb-body">${q.expl||''}</div>`;
  if(window.MathJax)MathJax.typesetPromise([fb]);
 
  showScorePop(isCorrect,pts);
  if(isCorrect)launchConfetti(20);
  document.getElementById('btnNext').disabled=false;
  document.getElementById('btnSkip').style.display='none';
  updateHUD();
}
 
