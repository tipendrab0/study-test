      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:400,messages:[{role:'user',content:[
        {type:'image',source:{type:'base64',media_type:mtype,data:base64}},
        {type:'text',text:`Question: ${q.text}\n\nIs this handwritten answer correct? JSON only: {"correct":true/false,"feedback":"1-2 sentences","marks":"X/${q.points||2}"}`}
      ]}]})});
    const data=await resp.json();
