async function startCamera(){
  const ca=document.getElementById('cameraArea');
  if(!ca){showToast('Camera only works on subjective questions');return;}
  ca.classList.add('show');
  try{
    const stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});
    activeCameraStream=stream;
    const v=document.getElementById('cameraVideo');
    if(v) v.srcObject=stream;
  }catch(e){ca.classList.remove('show');showToast('Camera not available — try uploading instead');}
}
function stopCamera(){
  if(activeCameraStream){activeCameraStream.getTracks().forEach(t=>t.stop());activeCameraStream=null;}
  const ca=document.getElementById('cameraArea');
  if(ca) ca.classList.remove('show');
}
function snapPhoto(){
  const v=document.getElementById('cameraVideo'),c=document.getElementById('captureCanvas');
  if(!v||!c)return;
  c.width=v.videoWidth;c.height=v.videoHeight;c.getContext('2d').drawImage(v,0,0);
  capturedImageData=c.toDataURL('image/jpeg',0.8);
  stopCamera();showImagePreview(capturedImageData);gradeWithAI(capturedImageData);
}
function handleImgUpload(e){
  const file=e.target.files[0];if(!file)return;
  const r=new FileReader();r.onload=ev=>{capturedImageData=ev.target.result;showImagePreview(capturedImageData);gradeWithAI(capturedImageData);};r.readAsDataURL(file);
}
function showImagePreview(src){
  const img=document.getElementById('imgPreview');
  const area=document.getElementById('imgPreviewArea');
  const sb=document.getElementById('btnSubmitAns');
  if(img) img.src=src;
  if(area) area.classList.add('show');
  if(sb) sb.classList.add('show');
}
