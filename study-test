const uploadZone = document.getElementById('uploadZone');
const fileInput = document.getElementById('fileInput');
uploadZone.addEventListener('dragover', e=>{e.preventDefault();uploadZone.classList.add('dragover');});
uploadZone.addEventListener('dragleave', ()=>uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', e=>{
  e.preventDefault();uploadZone.classList.remove('dragover');
  if(e.dataTransfer.files.length) handleFileUpload(e.dataTransfer.files);
});
fileInput.addEventListener('change', e=>{
  if(e.target.files.length) handleFileUpload(e.target.files);
});
 
async function handleFileUpload(files) {
  const fileArr = Array.from(files);
  // Show file chips
  const chips = document.getElementById('fileChips');
  if(chips){
    chips.innerHTML = fileArr.map(f=>`<div class="file-chip">📄 <span>${f.name}</span></div>`).join('');
  }
 
  // Hide upload UI
  ['uploadZone','fileChips'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.style.display='none';
  });
  ['.or-divider','.skip-btn','.upload-title','.upload-sub'].forEach(s=>{
    const el=document.querySelector(s); if(el) el.style.display='none';
  });
  document.getElementById('aiProcessing').classList.add('show');
 
  // Process each file and merge
  const allQuestions = [];
  const stepsTotal = ['step1','step2','step3','step4','step5'];
 
  for(let fi=0; fi<fileArr.length; fi++){
    const file = fileArr[fi];
    // Animate steps for each file
    for(let si=0;si<stepsTotal.length;si++){
      const el=document.getElementById(stepsTotal[si]);
      if(el){ el.classList.remove('done'); el.classList.add('active');
        el.innerHTML=`<span style="width:7px;height:7px;border-radius:50%;background:currentColor;display:inline-block;flex-shrink:0"></span> ${getStepLabel(si, file.name, fi+1, fileArr.length)}`;}
      await new Promise(r=>setTimeout(r, fileArr.length>1 ? 500 : 900));
      if(el){ el.classList.remove('active'); el.classList.add('done'); }
    }
 
    let base64Data='', mediaType=file.type;
    if(file.type==='application/pdf'||file.type.startsWith('image/')){
      base64Data = await new Promise(res=>{const r=new FileReader();r.onload=()=>res(r.result.split(',')[1]);r.readAsDataURL(file);});
    }
    const qs = await extractFromFile(base64Data, mediaType);
    allQuestions.push(...qs);
  }
 
  if(allQuestions.length>0){
    questions = allQuestions; aiGenerated=true;
    showToast(`✨ Extracted ${allQuestions.length} questions from ${fileArr.length} file${fileArr.length>1?'s':''}!`);
  } else {
    questions = DEFAULT_QUESTIONS;
    showToast('Using default Real Numbers questions');
  }
  startQuiz();
}
 
function getStepLabel(si, fname, fi, total){
  const labels=['Reading document...','Identifying question types...','Extracting questions...','Generating explanations...','Preparing session...'];
  const base = labels[si] || 'Processing...';
  return total>1 ? `[${fi}/${total}] ${base} (${fname.substring(0,15)}...)` : base;
}
 
async function extractFromFile(base64Data, mediaType){
  try{
    const isPDF=mediaType==='application/pdf', isImg=mediaType.startsWith('image/');
    let content=[];
    if(isPDF) content.push({type:'document',source:{type:'base64',media_type:'application/pdf',data:base64Data}});
    else if(isImg) content.push({type:'image',source:{type:'base64',media_type:mediaType,data:base64Data}});
    content.push({type:'text',text:`Extract ALL questions from this document as a JSON array. Each question:
{"section":"section name","emoji":"emoji","type":"mcq"or"subj","points":1-4,"text":"question (LaTeX with \\\\( \\\\))","opts":["a","b","c","d"],"ans":0-3,"expl":"MCQ explanation","solution":"subjective solution"}
Return ONLY raw JSON array, no markdown, no extra text.`});
    const resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:4000,messages:[{role:'user',content}]})});
    const data=await resp.json();
    const text=data.content.map(c=>c.text||'').join('');
    const parsed=JSON.parse(text.replace(/```json|```/g,'').trim());
    return Array.isArray(parsed)?parsed:[];
  }catch(e){return [];}
}
 
