// ── NAVIGATION ──
function nextQuestion(counted){
  if(!currentAnswered&&counted)return;
  stopCamera();
  if(!currentAnswered){
    skipped++;streak=0;currentResult='skipped';
    const q=questions[currentIdx];
    questionLog.push({text:q.text,result:'skipped',points:q.points||1,earned:0});
  }
  const slide=document.getElementById('qSlide');
  slide.classList.remove('enter');slide.classList.add('exit-up');
  setTimeout(()=>{currentIdx++;
    if(isInfiniteMode&&currentIdx>=questions.length) generateMoreQuestions();
    else renderQuestion(currentIdx);
  },380);
}
 
// ── HUD ──
function updateHUD(){
  const total=questions.length;
  if(total===0){
    document.getElementById('progressFill').style.width='0%';
    document.getElementById('qCounter').textContent='— / —';
    document.getElementById('streakBadge').textContent='🔥 0';
    document.getElementById('scoreLive').textContent='★ 0';
    return;
  }
  const pct=isInfiniteMode?((currentIdx%10)/10*100):total>0?(currentIdx/total*100):0;
  document.getElementById('progressFill').style.width=pct+'%';
  document.getElementById('qCounter').textContent=isInfiniteMode?`∞ ${currentIdx+1}`:`${currentIdx+1} / ${total}`;
  document.getElementById('streakBadge').textContent=`🔥 ${streak}`;
  document.getElementById('scoreLive').textContent=`★ ${score}`;
}
 
