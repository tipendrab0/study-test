async function generateMoreQuestions(isFirst=false){
  const gen=document.getElementById('infiniteGenerating');
  gen.classList.add('show');
  document.getElementById('cardsContainer').classList.remove('show');
 
  const topics=['HCF and LCM applications','prime factorization','Euclid\'s division lemma','irrational numbers proofs','real-world HCF/LCM word problems','co-prime numbers','Fundamental Theorem of Arithmetic'];
  const topic=topics[Math.floor(Math.random()*topics.length)];
  const difficulty=infiniteCount<10?'medium':infiniteCount<20?'hard':'very hard';
 
  let count=0;
  const counter=document.getElementById('infGenCount');
  const countInterval=setInterval(()=>{count=Math.min(count+1,10);counter.textContent=count;},200);
 
  try{
    const resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:3000,messages:[{role:'user',content:`Generate exactly 10 unique CBSE Class 10 Real Numbers questions about "${topic}" at ${difficulty} difficulty. Mix of MCQ and subjective. JSON array only:
[{"section":"∞ Infinite Round","emoji":"♾️","type":"mcq"or"subj","points":1-4,"text":"question with LaTeX \\\\( \\\\)","opts":["a","b","c","d"],"ans":0-3,"expl":"explanation","solution":"solution"}]
No markdown, raw JSON only.`}]})});
    const data=await resp.json();
    const parsed=JSON.parse(data.content.map(c=>c.text||'').join('').replace(/```json|```/g,'').trim());
    clearInterval(countInterval);counter.textContent=parsed.length;
    await new Promise(r=>setTimeout(r,400));
 
    questions=[...questions,...parsed];
    infiniteCount+=parsed.length;
    gen.classList.remove('show');
 
    if(isFirst) showSectionBanner({section:'∞ Infinite Round',emoji:'♾️'},()=>renderQuestion(currentIdx));
    else renderQuestion(currentIdx);
  }catch(e){
    clearInterval(countInterval);gen.classList.remove('show');
    // fallback: remix existing default questions with shuffled order
    const remixed=[...DEFAULT_QUESTIONS].sort(()=>Math.random()-0.5).slice(0,10).map(q=>({...q,section:'∞ Infinite Round',emoji:'♾️'}));
    questions=[...questions,...remixed];
    infiniteCount+=10;
    if(isFirst) showSectionBanner({section:'∞ Infinite Round',emoji:'♾️'},()=>renderQuestion(currentIdx));
    else renderQuestion(currentIdx);
  }
}
 
