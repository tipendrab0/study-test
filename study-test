<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>StudyFlash ✦ Real Numbers</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/3.2.2/es5/tex-mml-chtml.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f0e17;
  --card: #1a1828;
  --card2: #211f33;
  --accent: #ff6b35;
  --accent2: #ffd166;
  --accent3: #06d6a0;
  --accent4: #a29bfe;
  --text: #fffffe;
  --muted: #a09fb1;
  --border: rgba(255,255,255,0.08);
  --green: #06d6a0;
  --red: #ef476f;
  --radius: 20px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg); color: var(--text);
  height: 100vh; display: flex; flex-direction: column; overflow: hidden;
}
 
/* blobs */
.blob-bg { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
.blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.13; animation: blobMove 12s ease-in-out infinite alternate; }
.blob1 { width: 420px; height: 420px; background: var(--accent); top: -120px; left: -120px; }
.blob2 { width: 360px; height: 360px; background: var(--accent4); bottom: -90px; right: -90px; animation-delay: 3s; }
.blob3 { width: 280px; height: 280px; background: var(--accent3); top: 40%; left: 40%; animation-delay: 6s; }
@keyframes blobMove { from { transform: translate(0,0) scale(1); } to { transform: translate(40px,30px) scale(1.1); } }
 
/* topbar */
.topbar {
  position: relative; z-index: 10;
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 20px;
  background: rgba(15,14,23,0.88); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.logo { font-family: 'Syne', sans-serif; font-size: 19px; font-weight: 800; cursor: pointer; user-select: none; transition: opacity 0.2s; }
.logo:hover { opacity: 0.75; }
.logo span { color: var(--accent); }
.topbar-right { display: flex; align-items: center; gap: 10px; }
.q-counter {
  font-size: 12px; font-weight: 700; color: var(--muted);
  background: var(--card2); padding: 5px 12px; border-radius: 20px;
}
.streak-badge {
  background: linear-gradient(135deg, var(--accent2), var(--accent));
  color: #0f0e17; font-weight: 800; font-size: 12px;
  padding: 5px 12px; border-radius: 20px;
}
.score-live {
  font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 800;
  color: var(--accent3); background: rgba(6,214,160,0.1);
  border: 1px solid rgba(6,214,160,0.25); padding: 5px 12px; border-radius: 20px;
}
 
/* progress */
.progress-track { height: 3px; background: var(--border); flex-shrink: 0; }
.progress-fill {
  height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2));
  transition: width 0.5s cubic-bezier(.4,0,.2,1); border-radius: 0 2px 2px 0;
}
 
/* main */
.main-area { flex: 1; position: relative; overflow: hidden; z-index: 5; }
 
/* ── UPLOAD ── */
.upload-screen {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 24px; gap: 18px; overflow-y: auto;
  transition: opacity 0.4s, transform 0.4s;
}
.upload-screen.hidden { opacity: 0; pointer-events: none; transform: translateY(-30px); }
.upload-title { font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 800; text-align: center; line-height: 1.2; }
.upload-title span { color: var(--accent); }
.upload-sub { color: var(--muted); text-align: center; font-size: 14px; max-width: 320px; line-height: 1.5; }
.upload-zone {
  width: 100%; max-width: 400px; border: 2px dashed var(--accent4); border-radius: var(--radius);
  padding: 32px 20px; text-align: center; cursor: pointer;
  background: rgba(162,155,254,0.05); transition: all 0.2s;
}
.upload-zone:hover { border-color: var(--accent); background: rgba(255,107,53,0.08); }
.upload-zone.dragover { border-color: var(--accent3); background: rgba(6,214,160,0.08); transform: scale(1.02); }
.upload-icon { font-size: 40px; margin-bottom: 8px; }
.upload-zone p { color: var(--muted); font-size: 13px; margin-top: 6px; }
.upload-zone strong { color: var(--text); font-size: 15px; }
#fileInput { display: none; }
.or-divider { display: flex; align-items: center; gap: 12px; width: 100%; max-width: 400px; color: var(--muted); font-size: 12px; }
.or-divider::before,.or-divider::after { content:''; flex:1; height:1px; background:var(--border); }
.skip-btn {
  background: var(--card2); border: 1px solid var(--border);
  color: var(--muted); padding: 12px 28px; border-radius: 50px;
  font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s;
}
.skip-btn:hover { color: var(--text); border-color: var(--accent4); }
.ai-processing { display: none; flex-direction: column; align-items: center; gap: 14px; text-align: center; }
.ai-processing.show { display: flex; }
.spinner { width: 44px; height: 44px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.ai-steps { display: flex; flex-direction: column; gap: 5px; width: 280px; }
.ai-step { font-size: 12px; color: var(--muted); padding: 7px 12px; background: var(--card); border-radius: 10px; text-align: left; display: flex; align-items: center; gap: 8px; transition: all 0.3s; }
.ai-step.active { color: var(--accent2); background: rgba(255,209,102,0.1); }
.ai-step.done { color: var(--accent3); }
 
/* ── CARDS ── */
.cards-container { position: absolute; inset: 0; display: flex; flex-direction: column; opacity: 0; pointer-events: none; transition: opacity 0.4s; }
.cards-container.show { opacity: 1; pointer-events: all; }
.card-viewport { flex: 1; position: relative; overflow: hidden; }
 
/* section banner */
.section-banner {
  position: absolute; inset: 0; z-index: 20;
  display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 10px;
  background: var(--bg); transform: translateY(100%); transition: transform 0.5s cubic-bezier(.4,0,.2,1); pointer-events: none;
}
.section-banner.show { transform: translateY(0); }
.section-banner.exit { transform: translateY(-100%); }
.section-banner h2 { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; text-align: center; }
.section-banner p { color: var(--muted); font-size: 15px; }
.section-banner .emoji { font-size: 48px; }
.infinite-banner-badge {
  background: linear-gradient(135deg, var(--accent2), var(--accent));
  color: #0f0e17; font-weight: 800; font-size: 12px; padding: 5px 16px;
  border-radius: 20px; letter-spacing: 0.05em;
}
 
/* q-slide */
.q-slide {
  position: absolute; inset: 0; overflow-y: auto; padding: 16px 16px 110px;
  transform: translateY(60px); opacity: 0; transition: all 0.45s cubic-bezier(.4,0,.2,1); pointer-events: none;
}
.q-slide.enter { transform: translateY(0); opacity: 1; pointer-events: all; }
.q-slide.exit-up { transform: translateY(-60px); opacity: 0; pointer-events: none; }
.q-card-inner { max-width: 580px; margin: 0 auto; }
 
/* score pop — appears above question after answer */
.score-pop {
  display: none; align-items: center; gap: 8px; justify-content: flex-end;
  margin-bottom: 10px; animation: popIn 0.4s cubic-bezier(.4,0,.2,1);
}
.score-pop.show { display: flex; }
.score-pop-pill {
  font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800;
  padding: 6px 18px; border-radius: 50px;
}
.score-pop-pill.correct { background: rgba(6,214,160,0.2); color: var(--green); border: 2px solid var(--green); }
.score-pop-pill.wrong { background: rgba(239,71,111,0.15); color: var(--red); border: 2px solid var(--red); }
.score-pop-pill.skipped { background: rgba(160,159,177,0.15); color: var(--muted); border: 2px solid var(--muted); }
.score-pop-label { font-size: 13px; font-weight: 700; color: var(--muted); }
@keyframes popIn { from { transform: scale(0.5) translateY(10px); opacity: 0; } to { transform: scale(1) translateY(0); opacity: 1; } }
 
/* running tally */
.running-tally {
  display: flex; align-items: center; gap: 6px; margin-bottom: 12px;
}
.tally-dot {
  width: 9px; height: 9px; border-radius: 50%;
  transition: background 0.3s;
}
.tally-dot.correct { background: var(--green); }
.tally-dot.wrong { background: var(--red); }
.tally-dot.skipped { background: var(--muted); opacity: 0.4; }
.tally-dot.pending { background: var(--border); border: 1px solid rgba(255,255,255,0.15); }
 
.q-top-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
.q-section-tag { font-size: 10px; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; padding: 4px 10px; border-radius: 20px; }
.tag-mcq { background: rgba(255,107,53,0.2); color: var(--accent); }
.tag-subj { background: rgba(162,155,254,0.2); color: var(--accent4); }
.tag-bonus { background: rgba(255,209,102,0.2); color: var(--accent2); }
.tag-infinite { background: rgba(6,214,160,0.2); color: var(--accent3); }
.q-num-big { font-size: 12px; color: var(--muted); font-weight: 700; margin-left: auto; }
.ai-badge { display:inline-flex; align-items:center; gap:4px; background:linear-gradient(135deg,rgba(162,155,254,0.2),rgba(255,107,53,0.2)); border:1px solid rgba(162,155,254,0.3); border-radius:20px; padding:3px 8px; font-size:10px; font-weight:800; color:var(--accent4); text-transform:uppercase; letter-spacing:0.1em; }
 
.q-text-box {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 20px 22px; margin-bottom: 16px; font-size: 15px; line-height: 1.7; font-weight: 600;
}
.q-points-badge {
  display: inline-flex; align-items: center; gap: 4px; margin-bottom: 12px;
  background: rgba(255,209,102,0.1); border: 1px solid rgba(255,209,102,0.25);
  padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 800; color: var(--accent2);
}
 
/* options */
.options-list { display: flex; flex-direction: column; gap: 9px; margin-bottom: 14px; }
.opt {
  background: var(--card2); border: 2px solid var(--border); border-radius: 14px;
  padding: 13px 16px; display: flex; align-items: flex-start; gap: 11px;
  cursor: pointer; transition: all 0.18s; font-size: 14px; font-weight: 600;
  -webkit-tap-highlight-color: transparent;
}
.opt:hover:not(.correct):not(.wrong):not(.reveal-correct) { border-color: var(--accent4); background: rgba(162,155,254,0.1); transform: translateX(4px); }
.opt-lbl {
  width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
  background: var(--border); display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 800; margin-top: 1px; transition: all 0.18s;
}
.opt.correct { border-color: var(--green); background: rgba(6,214,160,0.12); animation: boing 0.4s ease; }
.opt.correct .opt-lbl { background: var(--green); color: var(--bg); }
.opt.wrong { border-color: var(--red); background: rgba(239,71,111,0.12); animation: boing 0.4s ease; }
.opt.wrong .opt-lbl { background: var(--red); color: white; }
.opt.reveal-correct { border-color: var(--green); background: rgba(6,214,160,0.06); }
.opt.reveal-correct .opt-lbl { background: var(--green); color: var(--bg); }
@keyframes boing { 0%{transform:scale(1)} 40%{transform:scale(1.04)} 70%{transform:scale(0.97)} 100%{transform:scale(1)} }
 
/* feedback */
.feedback-box { border-radius: 14px; padding: 14px 16px; margin-bottom: 12px; display: none; animation: slideUp 0.3s ease; }
.feedback-box.show { display: block; }
.feedback-box.correct-fb { background: rgba(6,214,160,0.1); border: 1px solid rgba(6,214,160,0.3); }
.feedback-box.wrong-fb { background: rgba(239,71,111,0.09); border: 1px solid rgba(239,71,111,0.3); }
.feedback-box.info-fb { background: rgba(162,155,254,0.1); border: 1px solid rgba(162,155,254,0.3); }
@keyframes slideUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
.fb-headline { font-size: 14px; font-weight: 800; margin-bottom: 6px; display: flex; align-items: center; gap: 5px; }
.fb-body { font-size: 13px; line-height: 1.65; color: var(--muted); }
.fb-body strong { color: var(--text); }
 
/* subjective */
.subj-options { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
.subj-btn {
  border: 2px solid var(--border); border-radius: 14px; padding: 13px 16px;
  background: var(--card2); display: flex; align-items: center; gap: 12px;
  cursor: pointer; transition: all 0.18s; font-family: 'Nunito', sans-serif;
  font-size: 14px; font-weight: 700; color: var(--text);
}
.subj-btn:hover { border-color: var(--accent4); background: rgba(162,155,254,0.1); transform: translateX(4px); }
.subj-btn .icon { font-size: 20px; }
.subj-btn .desc { font-size: 11px; color: var(--muted); font-weight: 600; margin-top: 2px; }
.camera-area { display: none; flex-direction: column; align-items: center; gap: 10px; background: var(--card); border-radius: var(--radius); padding: 14px; margin-bottom: 12px; }
.camera-area.show { display: flex; }
#cameraVideo { width: 100%; max-width: 380px; border-radius: 12px; }
#captureCanvas { display: none; }
.cam-btn { padding: 10px 22px; border-radius: 50px; border: none; font-family: 'Nunito', sans-serif; font-size: 13px; font-weight: 800; cursor: pointer; transition: all 0.18s; }
.cam-snap { background: var(--accent); color: white; }
.cam-retake { background: var(--card2); color: var(--muted); border: 1px solid var(--border); }
.cam-row { display: flex; gap: 8px; }
.img-preview-area { display: none; margin-bottom: 12px; }
.img-preview-area.show { display: block; }
.img-preview-area img { width: 100%; max-width: 380px; border-radius: 12px; border: 2px solid var(--accent4); }
.text-answer-area { display: none; margin-bottom: 12px; }
.text-answer-area.show { display: block; }
.text-answer-area textarea { width: 100%; min-height: 76px; background: var(--card); border: 2px solid var(--border); border-radius: 14px; padding: 12px 14px; color: var(--text); font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 600; resize: none; outline: none; transition: border-color 0.2s; }
.text-answer-area textarea:focus { border-color: var(--accent4); }
 
/* bottom bar */
.bottom-bar {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 15;
  padding: 12px 16px 16px;
  background: linear-gradient(transparent, var(--bg) 28%);
}
.bottom-inner { max-width: 580px; margin: 0 auto; display: flex; gap: 8px; }
.btn-next {
  flex: 1; padding: 14px; border: none; border-radius: 50px;
  background: linear-gradient(135deg, var(--accent), #ff8c5a);
  color: white; font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 800;
  cursor: pointer; transition: all 0.2s; letter-spacing: 0.02em;
  display: flex; align-items: center; justify-content: center; gap: 6px;
  box-shadow: 0 6px 20px rgba(255,107,53,0.35);
}
.btn-next:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(255,107,53,0.45); }
.btn-next:disabled { opacity: 0.35; cursor: default; transform: none; box-shadow: none; }
.btn-skip { padding: 14px 18px; border-radius: 50px; background: var(--card2); border: 1px solid var(--border); color: var(--muted); font-family: 'Nunito', sans-serif; font-size: 13px; font-weight: 700; cursor: pointer; transition: all 0.2s; }
.btn-skip:hover { color: var(--text); }
.btn-submit-ans { flex: 1; padding: 13px; border: none; border-radius: 50px; background: var(--accent4); color: var(--bg); font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 800; cursor: pointer; transition: all 0.2s; display: none; align-items: center; justify-content: center; gap: 5px; }
.btn-submit-ans.show { display: flex; }
.btn-submit-ans:hover { opacity: 0.85; }
 
/* ── RESULTS SCREEN ── */
.results-screen {
  position: absolute; inset: 0; z-index: 30;
  display: flex; flex-direction: column; align-items: center;
  padding: 0; opacity: 0; pointer-events: none; transition: opacity 0.5s;
  background: var(--bg); overflow-y: auto;
}
.results-screen.show { opacity: 1; pointer-events: all; }
 
.results-hero {
  width: 100%; padding: 36px 20px 24px;
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  text-align: center;
  background: linear-gradient(180deg, rgba(255,107,53,0.08) 0%, transparent 100%);
}
.results-emoji { font-size: 56px; animation: popIn 0.5s cubic-bezier(.4,0,.2,1) both; }
@keyframes popIn { from{transform:scale(0);opacity:0} to{transform:scale(1);opacity:1} }
.results-title { font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 800; }
.results-score {
  font-family: 'Syne', sans-serif; font-size: 56px; font-weight: 800; line-height: 1;
  background: linear-gradient(135deg, var(--accent2), var(--accent));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.results-sub { color: var(--muted); font-size: 14px; max-width: 260px; line-height: 1.5; }
 
.results-stats {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  width: 100%; max-width: 380px; padding: 0 20px;
}
.res-box { background: var(--card); border-radius: 14px; padding: 14px 16px; }
.res-box .num { font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 800; color: var(--accent2); }
.res-box .lbl { font-size: 11px; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }
 
/* Per-question review */
.review-section {
  width: 100%; max-width: 580px; padding: 20px 20px 0;
}
.review-heading {
  font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 800; margin-bottom: 12px;
  display: flex; align-items: center; gap: 8px;
}
.review-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
.review-item {
  background: var(--card); border-radius: 14px; padding: 14px 16px;
  display: flex; align-items: flex-start; gap: 12px; border: 1px solid var(--border);
}
.review-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
.review-content { flex: 1; min-width: 0; }
.review-q { font-size: 13px; font-weight: 700; line-height: 1.4; color: var(--text); margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.review-detail { font-size: 12px; color: var(--muted); }
.review-score-pill {
  flex-shrink: 0; font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 800;
  padding: 3px 10px; border-radius: 20px; margin-top: 2px;
}
.rpill-correct { background: rgba(6,214,160,0.15); color: var(--green); }
.rpill-wrong { background: rgba(239,71,111,0.12); color: var(--red); }
.rpill-skipped { background: rgba(160,159,177,0.1); color: var(--muted); }
 
.results-btns {
  width: 100%; max-width: 380px; padding: 20px 20px 40px;
  display: flex; flex-direction: column; gap: 10px;
}
.restart-btn {
  width: 100%; background: linear-gradient(135deg, var(--accent), #ff8c5a);
  border: none; color: white; padding: 15px; border-radius: 50px;
  font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 800;
  cursor: pointer; box-shadow: 0 6px 20px rgba(255,107,53,0.35); transition: all 0.2s;
}
.restart-btn:hover { transform: translateY(-2px); }
.infinite-btn {
  width: 100%; background: linear-gradient(135deg, var(--accent3), #0bb88a);
  border: none; color: var(--bg); padding: 15px; border-radius: 50px;
  font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 800;
  cursor: pointer; box-shadow: 0 6px 20px rgba(6,214,160,0.3); transition: all 0.2s;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.infinite-btn:hover { transform: translateY(-2px); }
 
/* ── INFINITE ROUND UI ── */
.infinite-generating {
  position: absolute; inset: 0; z-index: 25; background: var(--bg);
  display: none; flex-direction: column; align-items: center; justify-content: center;
  gap: 18px; text-align: center; padding: 24px;
}
.infinite-generating.show { display: flex; }
.inf-spinner {
  width: 56px; height: 56px; position: relative;
}
.inf-spinner::before, .inf-spinner::after {
  content: ''; position: absolute; inset: 0; border-radius: 50%;
  border: 3px solid transparent;
}
.inf-spinner::before { border-top-color: var(--accent3); animation: spin 1s linear infinite; }
.inf-spinner::after { border-bottom-color: var(--accent4); animation: spin 1.5s linear infinite reverse; inset: 6px; }
.inf-gen-title { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; }
.inf-gen-sub { color: var(--muted); font-size: 14px; max-width: 280px; line-height: 1.5; }
.inf-gen-count { font-family: 'Syne', sans-serif; font-size: 40px; font-weight: 800; color: var(--accent3); }
 
/* infinite topbar indicator */
.infinite-indicator {
  display: none; align-items: center; gap: 6px;
  background: rgba(6,214,160,0.15); border: 1px solid rgba(6,214,160,0.3);
  padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 800; color: var(--accent3);
}
.infinite-indicator.show { display: flex; }
.inf-pulse { width: 7px; height: 7px; border-radius: 50%; background: var(--accent3); animation: pulse 1.2s ease-in-out infinite; }
