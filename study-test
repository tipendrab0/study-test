    }
    if(result.correct){score+=pts;streak++;if(streak>bestStreak)bestStreak=streak;launchConfetti(20);}else streak=0;
    currentResult=result.correct?'correct':'wrong';
    questionLog.push({text:q.text,result:currentResult,points:pts,earned});
