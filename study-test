function showResults(){
  document.getElementById('cardsContainer').classList.remove('show');
  const rs=document.getElementById('resultsScreen');rs.classList.add('show');
 
  const total=questions.length;
  const acc=answered>0?Math.round(score/answered*10)/10:0; // score per question avg
  const pct=answered>0?Math.round((questionLog.filter(q=>q.result==='correct').length/answered)*100):0;
  const maxPossible=questions.reduce((s,q)=>s+(q.points||1),0);
 
  document.getElementById('resultsEmoji').textContent=pct>=80?'🏆':pct>=60?'🎉':pct>=40?'😊':'💪';
  document.getElementById('resultsTitle').textContent=pct>=80?'Absolute Legend!':pct>=60?'Great work!':pct>=40?'Getting there!':'Keep going!';
  document.getElementById('resultsScore').textContent=`${score}/${maxPossible}`;
  document.getElementById('resultsSub').textContent=`${pct}% accuracy · ${answered} questions attempted`;
  document.getElementById('resCorrect').textContent=questionLog.filter(q=>q.result==='correct').length;
  document.getElementById('resSkipped').textContent=questionLog.filter(q=>q.result==='skipped').length;
  document.getElementById('resStreak').textContent=bestStreak;
  document.getElementById('resAccuracy').textContent=pct+'%';
 
  // Per-question review
  const list=document.getElementById('reviewList');
  list.innerHTML=questionLog.map((item,i)=>{
    const icon=item.result==='correct'?'✅':item.result==='wrong'?'❌':'⏭️';
    const pillClass=item.result==='correct'?'rpill-correct':item.result==='wrong'?'rpill-wrong':'rpill-skipped';
    const pillText=item.result==='correct'?'+'+item.earned:item.result==='wrong'?'0/'+item.points:'skipped';
    const shortQ=item.text.replace(/\\[\(\)]/g,'').replace(/\\.{1,5}/g,'').substring(0,60)+(item.text.length>60?'…':'');
    return `<div class="review-item">
      <div class="review-icon">${icon}</div>
      <div class="review-content">
        <div class="review-q">Q${i+1}: ${shortQ}</div>
        <div class="review-detail">${item.points} point${item.points>1?'s':''} available</div>
      </div>
      <div class="review-score-pill ${pillClass}">${pillText}</div>
    </div>`;
  }).join('');
 
  if(pct>=60)launchConfetti(60);
}
 
